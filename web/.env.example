NEXT_PUBLIC_MONETAG_DIRECT_LINK=
NEXT_PUBLIC_MONETAG_DIRECT_LINK_ZONE=11257226

NEXT_PUBLIC_MONETAG_INVOKE_SCRIPT=
NEXT_PUBLIC_MONETAG_SCRIPT_IPP=

