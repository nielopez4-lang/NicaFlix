# NicaFlix Web — Vercel
NEXT_PUBLIC_SITE_URL=https://web-five-plum-og6kinpc9v.vercel.app

# Monetag — Zone ID del MultiTag (número en la URL del script)
# Guía completa: ../MONETAG.md
NEXT_PUBLIC_MONETAG_ZONE_ID=

# Verificación Monetag (solo el valor content= del meta tag)
NEXT_PUBLIC_MONETAG_VERIFY=

# Zona extra deportes (opcional)
NEXT_PUBLIC_MONETAG_ZONE_DEPORTES=

# APK Android (URL después de eas build)
NEXT_PUBLIC_ANDROID_APK_URL=
NEXT_PUBLIC_IOS_APP_URL=
