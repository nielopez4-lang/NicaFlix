# NicaFlix Web — Vercel
# Prefijo estándar: NEXT_PUBLIC_
# (Legacy SIGUIENTE_* sigue funcionando vía web/src/lib/env.ts durante migración)

NEXT_PUBLIC_SITE_URL=https://web-five-plum-og6kinpc9v.vercel.app

# MultiTag global (head)
NEXT_PUBLIC_MONETAG_ZONE_ID=
NEXT_PUBLIC_MONETAG_SCRIPT_SRC=

# Direct link Monetag (pre-roll / mid-roll)
